{
  "$defs": {
    "ExpenseCategory": {
      "enum": [
        "housing",
        "food",
        "transport",
        "utilities",
        "healthcare",
        "entertainment",
        "education",
        "personal",
        "shopping",
        "other"
      ],
      "title": "ExpenseCategory",
      "type": "string"
    }
  },
  "description": "Schema for categorizing a bank transaction description.",
  "properties": {
    "category": {
      "$ref": "#/$defs/ExpenseCategory",
