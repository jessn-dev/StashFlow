    "./mobile":   "./src/mobile.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stashflow/core": "workspace:*",
    "@supabase/supabase-js": "^2.105.4",
    "@supabase/ssr": "^0.10.3"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
