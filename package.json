{
  "name": "stashflow",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "start:all": "./setup.sh start:all",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' turbo run dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' turbo run build",
    "test": "NODE_OPTIONS='--max-old-space-size=8192' turbo run test",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=8192' turbo run test:coverage",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' turbo run typecheck",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' turbo run lint",
    "prepare": "husky",
    "gen:schemas": "turbo run gen:schemas",
    "gen:types": "supabase gen types typescript --local | tail -n +2 > packages/core/src/schema/database.types.ts"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9",
    "lint-staged": "^15",
    "turbo": "^2.9.12",
    "typescript": "^5.9.0"
  },
  "volta": {
    "node": "24.x",
    "pnpm": "10.33.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'pnpm test --filter=...[HEAD]'"
    ]
  },
  "pnpm": {
    "overrides": {
      "next": "^16.2.6",
      "postcss": "^8.5.10",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "@xmldom/xmldom": "^0.8.13",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "^19",
      "@types/react-dom": "^19"
    }
  }
}
