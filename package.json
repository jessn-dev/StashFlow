{
  "name": "stashflow",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "prepare": "husky",
    "gen:types": "supabase gen types typescript --local | tail -n +2 > packages/core/src/schema/database.types.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9",
    "lint-staged": "^15",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'pnpm test --filter=...[HEAD]'"
    ]
  }
}
