# Supabase Edge Function environment variables
# Populated automatically by ./setup.sh dev and ./setup.sh db:reset
# Never commit the real .env — add secrets to Supabase Dashboard > Project Settings > Edge Functions

# Supabase (set by setup.sh)
SUPABASE_URL=http://supabase_kong_<project>:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (set manually)
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=   # Requires billing enabled in Google Cloud Console
ANTHROPIC_API_KEY=

# Webhooks
PARSE_LOAN_WEBHOOK_SECRET=

# Cron jobs
CRON_SECRET=

# Local dev only — generated by ./setup.sh db:jwt, do not set manually
DEV_SERVICE_ROLE_JWT=
