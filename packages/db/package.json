{
  "name": "@stashflow/db",
  "version": "0.1.0",
  "description": "Typed Supabase client factories — platform-specific subpath exports",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".":          "./src/index.ts",
